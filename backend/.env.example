# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your_strong_jwt_secret_here

# Administrator Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/fitzone?retryWrites=true&w=majority
MONGODB_DB=fitzone

# Production Frontend URL (for CORS — set this to your Vercel app URL in production)
FRONTEND_URL=https://your-vercel-app.vercel.app
